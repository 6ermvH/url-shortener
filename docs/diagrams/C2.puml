@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title C2 Container: URL Shortener

Person(user, "Пользователь", "Отправляет запросы на сокращение и разрешение ссылок")

System_Boundary(system, "URL Shortener") {
    Container(api, "HTTP API Service", "Go", "Принимает HTTP-запросы, генерирует короткие ссылки, разрешает их в оригинальные URL")

    ContainerDb(postgres, "PostgreSQL", "SQL Database", "Хранит маппинг коротких ссылок на оригинальные URL")

    ContainerDb(memory, "In-Memory Storage", "Go map", "Альтернативное хранилище в памяти приложения")
}

Rel_R(user, api, "POST / — сокращение URL\nGET /{short} — получение оригинального URL", "HTTP/JSON")
Rel_D(api, postgres, "Читает и записывает маппинг ссылок", "SQL")
Rel_D(api, memory, "Читает и записывает маппинг ссылок", "Go API")

@enduml
